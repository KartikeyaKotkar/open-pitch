{
    "manifest_version": 3,
    "name": "OpenPitch",
    "version": "1.0",
    "description": "Free and Open Source Pitch Changer for YouTube",
    "permissions": [
        "activeTab"
    ],
    "host_permissions": [
        "*://*.youtube.com/*"
    ],
    "action": {
        "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.youtube.com/*"
            ],
            "js": [
                "content.js"
            ]
        }
    ]
}