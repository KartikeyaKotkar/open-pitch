{
    "manifest_version": 3,
    "name": "OpenPitch",
    "version": "1.0",
    "description": "Change the pitch of YouTube videos. Free, open source, no limits.",
    "permissions": [
        "activeTab",
        "scripting",
        "storage"
    ],
    "host_permissions": [
        "https://www.youtube.com/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "OpenPitch"
    },
    "content_scripts": [
        {
            "matches": [
                "https://www.youtube.com/*"
            ],
            "js": [
                "soundtouch-web-audio.js",
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ]
}